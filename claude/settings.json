{
  "permissions": {
    "allow": [
      "Bash(journalctl *)",
      "Bash(getent *)",
      "Bash(zcat *)",
      "Bash(zgrep *)",
      "Bash(dpkg -l *)",
      "Bash(dpkg -S *)",
      "Bash(apt-cache *)",
      "Bash(fail2ban-client status *)",
      "Bash(systemctl status *)",
      "Bash(systemctl is-active *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/check-secrets.sh",
            "statusMessage": "Checking for secret files..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -qP '(?:^|&&|\\|\\||;|\\()\\s*sudo\\b' && printf '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"sudo blocked — show the command for the user to run manually\"}}' || true"
          }
        ]
      }
    ]
  },
  "theme": "light",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "effortLevel": "high"
}
